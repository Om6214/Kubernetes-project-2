# Frontend Environment Configuration
# API Configuration (for local development - use API Gateway)
VITE_API_BASE_URL=http://localhost:3000/api
VITE_APP_NAME=Event Management System
VITE_APP_VERSION=1.0.0

# Application Settings
VITE_DEFAULT_PAGE_SIZE=10
VITE_MAX_FILE_UPLOAD_SIZE=5242880
VITE_SUPPORTED_FILE_TYPES=image/jpeg,image/png,image/gif

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=false

# Authentication
VITE_TOKEN_STORAGE_KEY=event_app_token
VITE_TOKEN_REFRESH_THRESHOLD=300000

# UI Configuration
VITE_THEME=default
VITE_TOAST_DURATION=4000
# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGO_DATABASE=event_bookings_db

# JWT Configuration (for token verification)
JWT_SECRET=your-super-secret-jwt-key-here

# Server Configuration
PORT=3003
NODE_ENV=development

# Service URLs (for inter-service communication) - CRITICAL: NO LOCALHOST!
EVENT_SERVICE_URL=http://event-svc:3002
AUTH_SERVICE_URL=http://auth-svc:3001